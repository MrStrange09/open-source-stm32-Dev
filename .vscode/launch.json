{
  "version": "0.2.0",
  "configurations": [
    // Debug the app firmware on a Nucleo-F411RE using the onboard ST-Link via OpenOCD.
    {
      "name": "ST-Link: Debug Application",
      "cwd": "${workspaceFolder}/app",
      "executable": "${workspaceFolder}/app/firmware.elf",
      "request": "launch",
      "type": "cortex-debug",
      "servertype": "openocd",
      "device": "STM32F411RE",
      "gdbPath": "${workspaceFolder}/.vscode/gdb-multiarch-nx",
      "searchDir": [
        "/usr/share/openocd/scripts"
      ],
      "configFiles": [
        "interface/stlink.cfg",
        "target/stm32f4x.cfg"
      ],
      "showDevDebugOutput": "raw",
      "runToEntryPoint": "main",
      "preLaunchTask": "build_debug"
    }
  ]
}
